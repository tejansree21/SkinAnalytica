{
  "version": 2,
  "name": "skinanalytica",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "pages/**",
      "use": "@vercel/static"
    },
    {
      "src": "skinanalytica_docs.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/",           "dest": "/index.html" },
    { "src": "/docs",       "dest": "/skinanalytica_docs.html" },
    { "src": "/pages/(.*)", "dest": "/pages/$1" },
    { "src": "/(.*)",       "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
